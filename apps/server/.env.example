# Server port (Fly.io sets this automatically via [env] in fly.toml)
PORT=3001

# Comma-separated list of allowed CORS origins
# Production: your Vercel app URL
# Dev: Expo dev server
ALLOWED_ORIGINS=http://localhost:8081,https://your-app.vercel.app

# Clerk — for JWT verification on socket handshake (Phase 5)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Supabase — for game session persistence (Phase 4)
# Use service role key (server-side only, never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sentry — error tracking only (Phase 6)
SENTRY_DSN=https://...@sentry.io/...
